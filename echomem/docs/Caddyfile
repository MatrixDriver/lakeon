# echomem 文档站 — Railway 部署配置
# Railway 注入 PORT env var, fallback 8080

:{$PORT:8080} {
	route {
		# 健康检查端点 — 免认证
		handle /healthz {
			respond "OK" 200
		}

		# 密码认证
		basic_auth {
			echomem $2a$14$r1oIAqQsMqPd/rSwEAP0H.zsoNakou5YSoOOVBDLRXCxBUI/msJ7.
		}

		root * /srv
		encode gzip zstd
		file_server

		# 入口 redirect: / → 痛点（首页）
		redir / /pain-points/ 302

		# Markdown 文件 Content-Type
		@md path *.md
		header @md Content-Type "text/markdown; charset=utf-8"

		# 安全 headers
		header {
			X-Content-Type-Options nosniff
			X-Frame-Options DENY
			Referrer-Policy strict-origin-when-cross-origin
			Strict-Transport-Security "max-age=31536000"
			-Server
		}

		# 阻止访问隐藏文件
		@hidden path */.*
		handle @hidden {
			respond "Not Found" 404
		}
	}

	# 访问日志（必须在 route 外部）
	log {
		output stdout
		format console
		level INFO
	}

	handle_errors {
		respond "{err.status_code} {err.status_text}"
	}
}
