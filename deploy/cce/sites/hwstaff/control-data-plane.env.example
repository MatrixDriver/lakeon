# Optional split-cluster deployment variables.
# Keep real values in sites/hwstaff/.env or export them in the shell.

# Data-plane private endpoint used by control-plane lakeon-api to call pageserver.
DATA_PLANE_PAGESERVER_URL=http://<data-plane-private-elb>:9898

# Data-plane Kubernetes API credentials. deploy-control-plane.sh can derive these
# from SITE_DATA_KUBECONFIG after data-plane RBAC exists, so these are optional.
DATA_PLANE_KUBE_API_SERVER=https://<data-plane-cce-api-server>:5443
DATA_PLANE_KUBE_CA_B64=<certificate-authority-data>
DATA_PLANE_KUBE_TOKEN=<service-account-token>

# Data-plane proxy calls this control-plane endpoint for Neon proxy auth.
CONTROL_PLANE_PROXY_AUTH_ENDPOINT=http://<control-plane-private-elb>:8088/proxy

# Optional pageserver private ELB binding for cross-CCE traffic.
DATA_PLANE_PAGESERVER_SERVICE_TYPE=LoadBalancer
DATA_PLANE_PAGESERVER_ELB_ID=<private-elb-id>
DATA_PLANE_PAGESERVER_ELB_CLASS=performance
